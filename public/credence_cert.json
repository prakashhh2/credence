        {
          "name": "degree_title",
          "type": "string"
        },
        {
          "name": "student_id",
          "type": "string"
        },
        {
          "name": "issue_date",
          "type": "string"
        },
        {
          "name": "ipfs_cid",
          "type": "string"
        }
