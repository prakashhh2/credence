            ],
            "type": "string"
          },
          {
            "name": "degree_title",
            "docs": [
              "Full degree or certificate title"
            ],
            "type": "string"
          },
          {
            "name": "student_id",
            "docs": [
              "Student ID issued by the university"
            ],
            "type": "string"
          },
          {
            "name": "issue_date",
            "docs": [
