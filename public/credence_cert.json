            ],
            "type": "string"
          },
          {
            "name": "ipfs_cid",
            "docs": [
              "Pinata / IPFS CID of the certificate document"
            ],
            "type": "string"
          },
          {
            "name": "issuer",
            "docs": [
              "Wallet of the university admin that issued the certificate"
            ],
            "type": "pubkey"
          },
          {
            "name": "issued_at",
            "docs": [
